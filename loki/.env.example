# Loki AI — Environment Variables
# Copy this file to .env and fill in your values

# OpenRouter API key (free at openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Picovoice Porcupine wakeword key (free tier available)
# Get from console.picovoice.ai
PORCUPINE_ACCESS_KEY=your_porcupine_key_here

# Optional: Loki vault master password (set on first run)
# LOKI_VAULT_PASSWORD=

# Optional: Override LLM model
# LOKI_LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
