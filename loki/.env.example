# Loki AI — Environment Variables
# Copy this file to .env and fill in your values

# ─── Primary LLM: Kimi K2 (Moonshot API) ───────────────────────────────────
# Get your key at: platform.moonshot.cn
# This is the fastest and smartest provider — set this first
KIMI_API_KEY=your_kimi_api_key_here

# ─── Fallback LLM: OpenRouter ───────────────────────────────────────────────
# Free at: openrouter.ai/keys
# Used when Kimi K2 is unavailable or rate-limited
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Local LLM: Ollama ──────────────────────────────────────────────────────
# Install Ollama from ollama.ai, then run: ollama pull phi3:mini
# Used as last-resort offline fallback — no key needed

# ─── Optional ───────────────────────────────────────────────────────────────
# Picovoice Porcupine wakeword (better "Hey Loki" detection)
# Get from: console.picovoice.ai (free tier)
# PORCUPINE_ACCESS_KEY=your_porcupine_key_here

# Loki vault master password (set on first run)
# LOKI_VAULT_PASSWORD=

# Override Kimi model (default: kimi-k2)
# KIMI_MODEL=moonshot-v1-128k
