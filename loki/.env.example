# Loki AI — Environment Variables
# Copy this file to .env and fill in your keys

# ─── PRIMARY (fast, ~2-3s): OpenRouter ──────────────────────────────────────
# Free at: openrouter.ai/keys
# Powers the fast free models (GPT-OSS-120B, Gemma-4-31B, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── DEEP REASONING: NVIDIA NIM — Kimi K2.6 ────────────────────────────────
# Get from: build.nvidia.com (free credits)
# Used when nvidia_thinking: true in config.yaml — slow but very smart
# Leave as-is if you want fast mode (thinking: false, still uses this key)
NVIDIA_API_KEY=your_nvidia_api_key_here

# ─── OPTIONAL: Kimi Moonshot direct API ─────────────────────────────────────
# Get from: platform.moonshot.cn
KIMI_API_KEY=your_kimi_api_key_here

# ─── OPTIONAL: Ollama (local, offline) ──────────────────────────────────────
# Install: winget install Ollama.Ollama
# Then: ollama serve && ollama pull phi3:mini
# No key needed — Loki auto-detects Ollama on localhost:11434

# ─── OPTIONAL: Porcupine wakeword ───────────────────────────────────────────
# Better "Hey Loki" detection (free tier at console.picovoice.ai)
# PORCUPINE_ACCESS_KEY=your_porcupine_key_here
